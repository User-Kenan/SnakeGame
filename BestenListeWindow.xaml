<Window x:Class="SnakeGame.BestenListeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnakeGame"
        mc:Ignorable="d"
        Title="BestenListeWindow" Height="450" Width="800">

    <Window.Background>
        <ImageBrush ImageSource="walloffame_picture.png"></ImageBrush>
    </Window.Background>
    <Grid>
        <ListBox Name="WallOfFameList" Background="Transparent" Margin="32,136,431,29" RenderTransformOrigin="0.5,0.5" BorderThickness="0">
            <ListBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.093"/>
                    <TranslateTransform/>
                </TransformGroup>
            </ListBox.RenderTransform>
        </ListBox>
        <Button Content="Back" HorizontalAlignment="Left" Margin="654,365,0,0" VerticalAlignment="Top" Height="41" Width="115" Click="Button_Click"/>
    </Grid>
    

</Window>
