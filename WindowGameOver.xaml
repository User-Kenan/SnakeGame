<Window x:Class="SnakeGame.WindowGameOver"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnakeGame"
        mc:Ignorable="d"
        Title="WindowGameOver" Height="350" Width="600">

    
    <Grid Background="Black">
        <TextBlock Text="GAME OVER!" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="30" Foreground="Red"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Save" Margin="5" Padding="5" Click="ButtonSave_Click" Height="50" Width="100"/>
            <Button Content="Menu" Margin="5" Padding="5" Click="ButtonMenu_Click" Height="50" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
