<Window x:Class="SnakeGame.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnakeGame"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="450" Width="800">
    <Grid Background="LightGray">
        <TextBlock Text="Settings" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="50"/>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions >
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <Label Grid.Row="0" Grid.Column="0" Content="Your Name:" HorizontalAlignment="Right" FontSize="22" Margin="5" />
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="InputName" FontSize="18" Margin="5" TextChanged="InputName_TextChanged"/>


            <Label Grid.Row="1" Grid.Column="0" Content="Speed:" HorizontalAlignment="Right" FontSize="22" Margin="5"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="InputSpeed" FontSize="18" Margin="5" MinWidth="200" TextChanged="InputSpeed_TextChanged"/>


            <Label Grid.Row="2" Grid.Column="0" Content="Playground size:" HorizontalAlignment="Right" FontSize="22" Margin="5"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="InputPlaygroundSize" FontSize="18" Margin="5" TextChanged="InputPlaygroundSize_TextChanged"/>


            <Label Grid.Row="3" Grid.Column="0" Content="Start Length:" HorizontalAlignment="Right" FontSize="22" Margin="5"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="InputStartLength" FontSize="18" Margin="5" TextChanged="InputStartlength_TextChanged"/>

            <Button Content="Start" x:Name="ButtonGameStart" Margin="5" Padding="5" Grid.Row="4" Grid.Column="1" Click="ButtonGameStart_Click"/>
            <Button Content="Back" x:Name="ButtonBackToMenu" Margin="5" Padding="5" Grid.Row="4" Grid.Column="0" Click="ButtonBackToMenu_Click"/>




        </Grid>
        



    </Grid>
</Window>
